# ── Zoho OAuth ──────────────────────────────────────────────────────────────
# Create a server-based OAuth client at https://api-console.zoho.in/
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zoho_chatbot

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your_fernet_key_here

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: bedrock (default), gemini
LLM_PROVIDER=bedrock

# AWS Bedrock — leave ACCESS_KEY_ID/SECRET_ACCESS_KEY blank if using an IAM role
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=  # only needed for temporary credentials

# Google Gemini — only required when LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL_ID=gemini-1.5-flash

# ── Optional ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
